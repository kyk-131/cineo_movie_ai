# =============================================================================
# CINEO AI BACKEND CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# For development (SQLite)
DATABASE_URL=sqlite:///./cineo_ai.db

# For production (PostgreSQL)
# DATABASE_URL=postgresql://username:password@localhost:5432/cineo_ai

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=KQHbABIPIQmnOdA7w2HvgG0eP9GVfSc_by6NV9bDeZk
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# AI API KEYS - GET THESE FROM THE PROVIDERS
# =============================================================================

# REPLICATE API KEY
# Get from: https://replicate.com/account/api-tokens
# Sign up at https://replicate.com and go to Account > API Tokens
REPLICATE_API_TOKEN=r8_your_replicate_api_token_here

# HUGGING FACE API KEY  
# Get from: https://huggingface.co/settings/tokens
# Sign up at https://huggingface.co and go to Settings > Access Tokens
HUGGINGFACE_API_TOKEN=hf_your_huggingface_api_token_here

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Cineo AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# CORS SETTINGS
# =============================================================================
# Frontend URL for CORS (adjust based on your frontend port)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# CREDITS & BILLING
# =============================================================================
DEFAULT_FREE_CREDITS=100
MAX_CREDITS_PER_USER=10000

# =============================================================================
# LOCAL MODEL SETTINGS (OPTIONAL)
# =============================================================================
# Set to true if you want to use local Stable Diffusion models
ENABLE_LOCAL_MODELS=false
LOCAL_MODEL_CACHE_DIR=./models
GPU_DEVICE=cuda  # or 'cpu' if no GPU available

# =============================================================================
# EMAIL SETTINGS (FOR FUTURE EMAIL VERIFICATION)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# =============================================================================
# STORAGE SETTINGS
# =============================================================================
# Directory for storing generated content
STATIC_FILES_DIR=./app/static
GENERATED_FILES_DIR=./app/static/generated