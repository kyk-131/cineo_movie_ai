# Database
DATABASE_URL=postgresql://username:password@localhost:5432/cineo_ai
DATABASE_URL_DEV=sqlite:///./cineo_ai.db

# Security
SECRET_KEY=your-secret-key-here-make-it-very-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI APIs
REPLICATE_API_TOKEN=your-replicate-api-token
HUGGINGFACE_API_TOKEN=your-huggingface-api-token

# Application
ENVIRONMENT=development
DEBUG=true
APP_NAME=Cineo AI
APP_VERSION=1.0.0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Credits
DEFAULT_FREE_CREDITS=100
MONTHLY_CREDIT_RESET=500